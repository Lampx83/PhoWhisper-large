PHOWHISPER_MODEL=vinai/PhoWhisper-small
# PHOWHISPER_MODEL=vinai/PhoWhisper-large
PRELOAD_MODEL=1
MAX_UPLOAD_MB=100
CORS_ORIGINS=*
# Log tiến trình ASR (giây): docker logs -f
# ASR_HEARTBEAT_SEC=45
# ASR_LANGUAGE=vietnamese
# Để Whisper tự detect ngôn ngữ: ASR_LANGUAGE=
# Độ dài mỗi chunk SSE (giây) — POST /v1/transcribe/stream
# ASR_STREAM_CHUNK_SEC=60
# HF_TOKEN=
