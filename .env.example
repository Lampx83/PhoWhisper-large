PHOWHISPER_MODEL=vinai/PhoWhisper-small
# PHOWHISPER_MODEL=vinai/PhoWhisper-large
PRELOAD_MODEL=1
MAX_UPLOAD_MB=100
CORS_ORIGINS=*
# Log tiến trình ASR (giây): docker logs -f
# ASR_HEARTBEAT_SEC=45
# ASR_LANGUAGE=vietnamese
# Để Whisper tự detect ngôn ngữ: ASR_LANGUAGE=
# Độ dài mỗi chunk SSE (giây) — POST /v1/transcribe/stream
# ASR_STREAM_CHUNK_SEC=60
# --- Máy nhiều core (CPU hoặc tiền xử lý trước khi đưa lên GPU) ---
# TORCH_NUM_INTRAOP_THREADS=32
# TORCH_NUM_INTEROP_THREADS=4
# OMP_NUM_THREADS=32
# MKL_NUM_THREADS=32
# NUMEXPR_NUM_THREADS=32
# NVIDIA_TF32_OVERRIDE=1
# Bật return_timestamps (long-form) khi đoạn >= giây này — file ngắn nên để mặc định
# ASR_LONGFORM_MIN_SEC=28.5
# HF_TOKEN=
